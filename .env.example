# ═══════════════════════════════════════════════════════════════════════════
#  xNico — Environment Configuration Template
#  Copy this file to `.env` and fill in your own values.
#  Never commit your real `.env` (it is gitignored).
# ═══════════════════════════════════════════════════════════════════════════

# ── Required ────────────────────────────────────────────────────────────────
# Discord bot token        → https://discord.com/developers/applications
TOKEN=
# Application (client) ID   → Developer Portal → General Information
CLIENT_ID=
# Your Discord user ID (full bot owner / eval access)
OWNER_ID=

# ── Core settings ───────────────────────────────────────────────────────────
# Default prefix for message commands (defaults to "-")
PREFIX=-
# Log verbosity: NONE | ERROR | WARN | INFO | DEBUG  (defaults to INFO)
LOG_LEVEL=INFO

# ── Database (optional) ─────────────────────────────────────────────────────
# PostgreSQL connection string. If omitted, the bot runs fully on the local
# JSON store (json_stores/). A fallback URL is used automatically on failover.
DATABASE_URL=
FALLBACK_DATABASE_URL=

# ── Web / dashboard ports (optional) ────────────────────────────────────────
WEBHOOK_PORT=3000
DASHBOARD_PORT=3500

# ── Dashboard / Discord OAuth login ─────────────────────────────────────────
# The web dashboard signs users in with "Log in with Discord". For that to
# work you MUST set the client secret below and register the redirect URL in
# the Discord Developer Portal.
#
# Discord Developer Portal → your app → OAuth2:
#   • Client secret  → paste into DISCORD_CLIENT_SECRET
#   • Redirects      → add the EXACT callback URL(s) your dashboard runs on,
#                      e.g.  https://your-domain.com/api/auth/discord/callback
#                      and   http://localhost:3500/api/auth/discord/callback
#
# OAuth2 client secret (REQUIRED for dashboard login). CLIENT_ID above is reused.
DISCORD_CLIENT_SECRET=
# OAuth2 redirect/callback URL. Leave BLANK to auto-detect from the request
# host (works on localhost and most hosts incl. Vercel). Set it explicitly
# only if auto-detection guesses wrong behind an unusual proxy. It must match
# a "Redirects" entry in the Developer Portal exactly, e.g.
#   https://your-domain.com/api/auth/discord/callback
DISCORD_REDIRECT=
# Secret used to sign dashboard session tokens (JWT). Set a long random string
# in production — if unset, an insecure built-in fallback is used.
JWT_SECRET=
# Comma-separated list of browser origins allowed to call the dashboard API
# when the frontend is hosted on a different domain than the API. Leave blank
# when frontend + API share an origin (the common case).
DASHBOARD_CORS_ORIGINS=
# Optional public base URL of the dashboard frontend (used for some redirects).
FRONTEND_URL=

# ── AI & image APIs (optional — enable specific features) ───────────────────
# Groq API key powers AI chat, AI moderation, and screenshot verification.
GROQ_API_KEY=
AI_MODERATION_MODEL=llama-3.1-8b-instant
AI_MODERATION_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# OCR language packs for screenshot verification (defaults to "eng")
TESSERACT_LANGS=eng
# GIF providers for action commands (hug, pat, etc.)
TENOR_API_KEY=
GIPHY_API_KEY=
# Optional custom image-generation API base URL
IMAGE_API_URL=

# ── Voting / listing sites (optional) ───────────────────────────────────────
TOPGG_TOKEN=
TOPGG_WEBHOOK_SECRET=
DBL_WEBHOOK_SECRET=

# ── Audit webhooks (optional) ───────────────────────────────────────────────
PREMIUM_AUDIT_WEBHOOK=
MODERATION_AUDIT_WEBHOOK=

# ── Branding (optional — overrides defaults) ────────────────────────────────
BOT_NAME=xNico
BOT_WEBSITE=https://thenico.vercel.app
SUPPORT_SERVER=https://discord.gg/Zs35X7Umak
AI_OWNER_TITLE=
AI_OWNER_BIO=

# ── Developer / deploy flags (optional) ─────────────────────────────────────
# Force a clean slash-command re-register on next boot (true/false)
FORCE_SLASH_REGISTER=false
# Verbose auto-delete logging (set to "verbose")
DEBUG_AUTO_DELETE=
